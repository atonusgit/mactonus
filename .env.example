# Kopioi tämä nimellä ".env" ja täytä omat polkusi.
# .env on gitignored — se ei joudu git-historiaan.

# Obsidian-vaultin host-polku. Tämä mountataan konttiin /vault-polkuun
# ja host-skriptit lukevat siitä mm. nauhoitukset.
VAULT_HOST_PATH=''

# Ollama-mallit. Vaihda kun haluat testata eri mallia — muista ensin `ollama pull <malli>`.
# Defaultit löytyvät config.py:stä jos jätät arvon tyhjäksi tai poistat rivin.
MALLI_KUVAT='gemma4:e4b'
MALLI_TEKSTIT='gemma4:31b'
MALLI_KOMMENTOIJA='gemma4:31b'

# VoxCPM2:n äänireferenssi (tiedoston nimi voxcpm2_server.py:n voices/-kansiossa).
VOXCPM_REFERENSSI='tiedosto.wav'

# Whisper-malli (tiedoston nimi conf/whisper-models/-kansiossa).
# Lataa esim.: curl -LO https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<malli>.bin
WHISPER_MALLI='ggml-large-v3-turbo.bin'

# Yhden nauhoituspätkän pituus sekunteina (record_and_transcribe.sh).
# Lyhyempi → nopeampi feedback litteroinnista, mutta enemmän tiedostoja.
NAUHOITUS_PATKA_PITUUS='120'

# Kommentoijan kynnys: kuinka monta uutta litteroitua pätkää tarvitaan
# ennen kuin commenter.py laukaisee Ollama+VoxCPM2-kutsun.
# 1 = kommentoi heti kun pätkä on litteroitu; korkeampi = harvemmin, kontekstuaalisempi.
KOMMENTOIJA_KYNNYS='1'
