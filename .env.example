# Kopioi tämä nimellä ".env" ja täytä omat polkusi.
# .env on gitignored — se ei joudu git-historiaan.

# Obsidian-vaultin host-polku. Tämä mountataan konttiin /vault-polkuun
# ja host-skriptit lukevat siitä mm. nauhoitukset.
VAULT_HOST_PATH=''

# Paikalliset llama.cpp-mallit (yksi multimodaali malli hoitaa tekstin ja kuvat).
# Defaultit löytyvät config.py:stä jos jätät arvon tyhjäksi tai poistat rivin.
MALLI_KUVAT='qwen3.6:35b-a3b'
MALLI_TEKSTIT='qwen3.6:35b-a3b'
MALLI_KOMMENTOIJA='qwen3.6:35b-a3b'

# === Mistral-pilvimalli (YouTube-tiivistys, julkista dataa) ===
# Hae avain console.mistral.ai:sta. Ilman avainta tiivistys ohitetaan
# (litterointi tallentuu silti). Malli vaihdettavissa, oletus config.py:ssä.
MISTRAL_API_KEY=''
# MISTRAL_MALLI='mistral-small-latest'

# VoxCPM2:n äänireferenssi (tiedoston nimi voxcpm2_server.py:n voices/-kansiossa).
VOXCPM_REFERENSSI='tiedosto.wav'

# Whisper-malli (tiedoston nimi conf/whisper-models/-kansiossa).
# Lataa esim.: curl -LO https://huggingface.co/ggerganov/whisper.cpp/resolve/main/<malli>.bin
WHISPER_MALLI='ggml-large-v3-turbo.bin'

# Yhden nauhoituspätkän pituus sekunteina (record_and_transcribe.sh).
# Lyhyempi → nopeampi feedback litteroinnista, mutta enemmän tiedostoja.
NAUHOITUS_PATKA_PITUUS='120'

# Kommentoijan kynnys: kuinka monta uutta litteroitua pätkää tarvitaan
# ennen kuin commenter.py laukaisee LLM+VoxCPM2-kutsun.
# 1 = kommentoi heti kun pätkä on litteroitu; korkeampi = harvemmin, kontekstuaalisempi.
KOMMENTOIJA_KYNNYS='1'

# === Telegram-silta pi-botille ===
# Jätä TELEGRAM_BOT_TOKEN tyhjäksi jos et halua Telegram-bottia (silta ei käynnisty).
# 1) Luo botti @BotFatherilla -> saat tokenin.
# 2) Selvitä oma chat-id: lähetä botille viesti ja katso @userinfobot tai getUpdates.
# TURVA: vain listatut chatit pääsevät läpi (pi voi ajaa bashia ja kirjoittaa /vault:iin).
TELEGRAM_BOT_TOKEN=''
TELEGRAM_SALLITUT_CHATIT=''   # esim. '123456789' tai '123,456' usealle

# Valinnaiset hienosäädöt (oletukset toimivat sellaisenaan):
# PI_TYOHAKEMISTO='/vault'   # pi:n työhakemisto kontissa
# PI_AIKAKATKAISU='600'      # yhden vastauksen aikaraja sekunteina
# PI_MALLI=''                # pakota malli, esim. 'qwen3.6:35b'
